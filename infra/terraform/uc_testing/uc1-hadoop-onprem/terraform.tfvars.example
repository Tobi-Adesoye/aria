project_id       = "aria-uc1-hadoop"
billing_account  = "XXXXXX-XXXXXX-XXXXXX"
region           = "europe-west1"
zone             = "europe-west1-b"
allowed_ssh_cidr = "YOUR_IP/32"

# After deploying aria-platform, get the GKE NAT IP and set it here, then re-apply:
# gcloud compute addresses list --project=aria-platform
gke_egress_cidr = "0.0.0.0/0"   # tighten after GKE deploy

# Generate with: ssh-keygen -t ed25519 -f aria_uc1_key -C aria
aria_ssh_public_key  = "ssh-ed25519 AAAA... aria"
aria_ssh_private_key = "-----BEGIN OPENSSH PRIVATE KEY-----\nREPLACE_ME\n-----END OPENSSH PRIVATE KEY-----"
